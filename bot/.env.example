# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=

# Telegram API credentials (для команды /scan — полный список участников)
# Получить на https://my.telegram.org → "API development tools"
API_ID=
API_HASH=

# ID чата админа для уведомлений о заявках в зоне "review"
# Узнать свой ID: написать @userinfobot в Telegram
ADMIN_CHAT_ID=

# SpamWatch API токен (получить у @SpamWatchBot → /start → /token)
SPAMWATCH_TOKEN=

# Белый список user ID (через запятую) — автоматический approve
WHITELIST_IDS=

# Пороги скоринга
SCORE_APPROVE=20
SCORE_DECLINE=-10

# Тестовый режим: true = не отклоняет, только показывает логику
TEST_MODE=true

# Группы с автобаном новых подозрительных (через запятую: @username или chat_id)
# Бот должен быть админом с правом Ban users
AUTOBAN_CHATS=

# Уровень логирования: DEBUG, INFO, WARNING
LOG_LEVEL=INFO
